# Azure Entra ID credentials (Service Principal)
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# Target Azure Environment
AZURE_RESOURCE_GROUP=your-resource-group-here
AZURE_LOCATION=eastus

# Foundry endpoint (base URL without trailing slash)
FOUNDRY_ENDPOINT=https://<your-foundry-resource-name>.services.ai.azure.com

# Project name
PROJECT_NAME=your-project-name
AZURE_API_KEY=your-api-key-here

# Orchestrator Agent
AGENT_APP_ORCHESTRATOR=Orchestrator-Agent
AGENT_MODEL_ORCHESTRATOR=gpt-4.1

# HR Agent
AGENT_APP_HR=HR-Agent
AGENT_MODEL_HR=gpt-4.1

# IT Agent
AGENT_APP_IT=ITSupport-Agent
AGENT_MODEL_IT=gpt-4.1

# Compliance Agent
AGENT_APP_COMPLIANCE=Compliance-Agent
AGENT_MODEL_COMPLIANCE=gpt-4.1

# Server port
PORT=3000

# Orchestration tuning
ROUTER_CONFIDENCE_THRESHOLD=0.75
