# Azure Entra ID credentials (Service Principal)
AZURE_TENANT_ID=<your-tenant-id>
AZURE_CLIENT_ID=<your-client-id>
AZURE_CLIENT_SECRET=<your-client-secret>

# Target Azure Environment
AZURE_RESOURCE_GROUP=<your-resource-group>
AZURE_LOCATION=<your-region>

# Foundry endpoint (base URL without trailing slash)
FOUNDRY_ENDPOINT=<your-foundry-endpoint>

# Project name
PROJECT_NAME=<your-project-name>

# Orchestrator Agent
AGENT_APP_ORCHESTRATOR=<orchestrator-agent-name>
AGENT_MODEL_ORCHESTRATOR=<orchestrator-model-name>

# HR Agent
AGENT_APP_HR=<hr-agent-name>
AGENT_MODEL_HR=<hr-model-name>

# IT Agent
AGENT_APP_IT=<it-agent-name>
AGENT_MODEL_IT=<it-model-name>

# Compliance Agent  
AGENT_APP_COMPLIANCE=<compliance-agent-name>
AGENT_MODEL_COMPLIANCE=<compliance-model-name>

# Server port
PORT=<server-port>
