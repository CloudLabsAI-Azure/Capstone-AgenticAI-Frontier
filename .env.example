# Azure Entra ID credentials (Service Principal)
AZURE_TENANT_ID=f871d17e-efcd-44c7-ba5a-0162efa2fded
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# Foundry endpoint (base URL without trailing slash)
FOUNDRY_ENDPOINT=https://my-foundry-2198385.services.ai.azure.com

# Project name
PROJECT_NAME=my-project

# Orchestrator Agent
AGENT_APP_ORCHESTRATOR=Orchestrator-Agent
AGENT_MODEL_ORCHESTRATOR=gpt-4.1-1

# HR Agent
AGENT_APP_HR=HR-Agent
AGENT_MODEL_HR=gpt-4.1-1

# IT Agent
AGENT_APP_IT=IT-Agent
AGENT_MODEL_IT=gpt-4.1-1

# Finance Agent  
AGENT_APP_FINANCE=Finance-Agent
AGENT_MODEL_FINANCE=gpt-4.1-1

# Server port
PORT=3000
